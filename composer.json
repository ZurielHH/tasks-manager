{
    "name": "zurielhh/tasks",
    "description": "Manage pending tasks",
    "keywords": ["tasks", "administrator"],
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Zuriel Hernández"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.5",
        "slim/slim": "4.*",
        "php-di/php-di": "^7.1",
        "slim/psr7": "^1.8",
        "ramsey/uuid": "^4.9",
        "doctrine/orm": "^3.6",
        "doctrine/dbal": "^4.4",
        "symfony/cache": "^8.0",
        "doctrine/migrations": "^3.9",
        "symfony/var-exporter": "^7.4",
        "php-di/slim-bridge": "^3.4"
    },
    "scripts": {
        "fix": "php-cs-fixer fix --config=dev/tools/.php-cs-fixer.dist.php"
    },
    "scripts-descriptions": {
        "fix": "Fix code style"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.92",
        "phpunit/phpunit": "^13.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
